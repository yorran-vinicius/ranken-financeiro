# ─────────────────────────────────────────────────────────────────────────────
# RANKEN Financeiro — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local — ele está no .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados Neon (PostgreSQL serverless)
# Obtenha em: https://console.neon.tech → seu projeto → Connection string
DATABASE_URL=postgres://usuario:senha@host/banco?sslmode=require

# Anthropic API — usada para análise de PDFs (importar fatura/extrato)
# Obtenha em: https://console.anthropic.com → API Keys
# Adicione no Vercel em: Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-api03-...

# Segredo de sessão (iron-session / cookie assinado)
# OBRIGATÓRIO em produção — use um valor aleatório de 32+ caracteres.
#
# Para gerar um valor seguro, execute no terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Exemplo (NÃO use este valor — gere o seu próprio):
SESSION_SECRET=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# Copie este arquivo para .env.local e preencha com os valores reais
# Obtenha o DATABASE_URL no painel do Vercel → Storage → seu banco Postgres
DATABASE_URL=postgres://usuario:senha@host/banco?sslmode=require

# Segredo para assinar o cookie de sessão (mínimo 32 caracteres, use um valor aleatório)
# Em desenvolvimento, um valor padrão é usado automaticamente — não precisa configurar
SESSION_SECRET=mude-este-valor-para-producao-use-32-chars
